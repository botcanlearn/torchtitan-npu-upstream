{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.agents/setup_agent.sh\" --agent codex --quiet || true",
            "timeout": 30,
            "statusMessage": "Syncing project skills and rules"
          }
        ]
      }
    ]
  }
}
